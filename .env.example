# 通用产品销售助手 - 环境配置示例
#
# 测试服务器: 106.12.40.212 (密码: Wulinjun@2)
# 部署路径: /opt/used-car-assistant
# 重启命令: systemctl restart used-car-assistant
#

# 生产环境数据库配置（服务器部署使用 MySQL）
DB_DRIVER=mysql
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=used_car
MYSQL_PASSWORD=UsedCar@2026!
MYSQL_DATABASE=used_car_assistant
MYSQL_CONNECTION_LIMIT=20

# AI 请求队列（润色 / 卖点 / 描述提取共用）
AI_QUEUE_CONCURRENCY=3
AI_QUEUE_MAX=30
AI_QUEUE_WAIT_MS=120000

# 登录鉴权（生产环境务必修改 AUTH_SECRET）
AUTH_SECRET=change-me-to-a-long-random-string
# AUTH_DEV_MODE=true   # 开发模式：验证码在 API 响应 devCode 中返回（生产请关闭）
# AUTH_DISABLED=true   # 仅本地调试，关闭登录

# 大模型文案（卖点生成 + 描述润色，使用 DeepSeek 等文本 API）
VISION_API_KEY=sk-xxx
VISION_API_URL=https://api.deepseek.com/chat/completions
VISION_MODEL=deepseek-chat
VISION_TIMEOUT_MS=45000
# SELLING_LLM_STRICT=true  # 无 Key 或 LLM 失败时不走本地模板兜底

# 对外访问地址（部署后改为新服务器 IP 或域名）
PUBLIC_BASE_URL=http://YOUR_SERVER_IP

# 系统配置管理员（逗号分隔；未设置时默认仅 13523515442 可访问三页配置）
# ADMIN_PHONES=13523515442
